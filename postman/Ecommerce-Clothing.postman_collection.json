    "name": "Ecommerce Clothing API",
    "description": "API surface for the clothing e-commerce app (Django + DRF backend, React frontend). Run requests top-to-bottom: Register/Login first to populate {{access_token}}, then Catalog -> Cart -> Orders.\n\nBase URL is set by the 'Ecommerce - Local' environment ({{base_url}} = http://localhost:8000/api), matching the docker-compose backend service on port 8000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "variable": [{ "key": "base_url", "value": "http://localhost:8000/api" }],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"jane_doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"StrongPassw0rd!\",\n  \"first_name\": \"Jane\",\n  \"last_name\": \"Doe\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.environment.set('access_token', data.access);",
                  "pm.environment.set('refresh_token', data.refresh);"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "Created",
              "code": 201,
              "status": "Created",
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"user\": {\n    \"id\": 1,\n    \"username\": \"jane_doe\",\n    \"email\": \"jane@example.com\",\n    \"first_name\": \"Jane\",\n    \"last_name\": \"Doe\",\n    \"date_joined\": \"2026-06-18T10:00:00Z\"\n  },\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.access...\",\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.refresh...\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "auth": { "type": "noauth" },
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"jane_doe\",\n  \"password\": \"StrongPassw0rd!\"\n}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json();",
                  "pm.environment.set('access_token', data.access);",
                  "pm.environment.set('refresh_token', data.refresh);"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "OK",
              "code": 200,
              "status": "OK",
